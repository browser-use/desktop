# ---------------------------------------------------------------------------
# Apple code signing + notarization environment variables
# Copy this file to .env and fill in real values — NEVER commit .env to git.
# ---------------------------------------------------------------------------

# Apple Developer Team ID
# Where to get it: https://developer.apple.com/account — upper right corner
# after logging in, or under Membership Details. 10-character alphanumeric.
APPLE_TEAM_ID=XXXXXXXXXX

# Apple ID email associated with your paid Apple Developer account
# This is the email you use to log in to developer.apple.com
APPLE_ID=you@example.com

# App-specific password (NOT your Apple ID login password)
# Where to get it: https://appleid.apple.com/account/manage
#   Sign in > App-Specific Passwords > Generate Password
# Format is four groups of four lowercase letters separated by dashes.
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Code signing identity string — must match exactly what Keychain reports.
# How to find it:
#   security find-identity -v -p codesigning
# The value will look like:
#   "Developer ID Application: Your Name (XXXXXXXXXX)"
# You need the "Developer ID Application" certificate type (NOT "Apple Development"
# or "Apple Distribution") — that requires a paid Apple Developer account.
SIGNING_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)

# ---------------------------------------------------------------------------
# GitHub Actions CI equivalents (set these as repository secrets, not here)
# These are listed here for documentation — do not put real values in this file.
# ---------------------------------------------------------------------------

# CSC_LINK: base64-encoded .p12 certificate file for electron-builder.
# Not used by this project (uses Electron Forge + codesign directly), but
# documented here for reference if the toolchain ever changes.
# How to export: Keychain Access > My Certificates > Developer ID Application
#   > right-click > Export > save as .p12 with a strong password
# How to encode: base64 -i certificate.p12 | pbcopy
# CSC_LINK=<base64-encoded .p12>

# CSC_KEY_PASSWORD: the password you set when exporting the .p12 above.
# CSC_KEY_PASSWORD=your-p12-export-password

# APPLE_DEVELOPER_CERTIFICATE_P12_BASE64: same as CSC_LINK — the base64
# .p12 content. Used in release.yml's "Import signing certificate" step.
# APPLE_DEVELOPER_CERTIFICATE_P12_BASE64=<base64-encoded .p12>

# APPLE_DEVELOPER_CERTIFICATE_PASSWORD: password for the .p12 export above.
# Used in release.yml's "Import signing certificate" step.
# APPLE_DEVELOPER_CERTIFICATE_PASSWORD=your-p12-export-password

# APPLE_SIGNING_IDENTITY: same as SIGNING_IDENTITY above.
# Used in release.yml to pass to sign-python.sh and forge.config.ts.
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)
